{
  "name": "@im-ian/claude-handoff",
  "version": "0.0.1",
  "description": "Hand off your Claude Code setup between devices — like Apple Handoff, but for ~/.claude/",
  "type": "module",
  "bin": {
    "handoff": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/im-ian/claude-handoff.git"
  },
  "homepage": "https://github.com/im-ian/claude-handoff#readme",
  "bugs": {
    "url": "https://github.com/im-ian/claude-handoff/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "claude",
    "sync",
    "dotfiles",
    "handoff",
    "devices"
  ],
  "author": "im-ian",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.9.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
